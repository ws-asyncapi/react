{
    "compilerOptions": {
        "lib": ["ESNext", "DOM"],
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "jsx": "react-jsx",
        "noEmit": true,
        "strict": true,
        "skipLibCheck": true,
        "paths": {
            "@ws-asyncapi/client": ["../client/src/index.ts"]
        }
    }
}
